{
    "name": "cyberline/filament-navigation-footermenu",
    "version": "1.0.1",
    "description": "Configurable footer navigation for Filament v4, v5: collapsible sidebar group and topbar dropdown (dark mode ready).",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "CyberLine",
            "homepage": "https://github.com/CyberLine"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0|^5.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Cyberline\\FilamentNavigationFootermenu\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Cyberline\\FilamentNavigationFootermenu\\FooterMenuServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
